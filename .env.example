# ==============================================
# Supabase Configuration (REQUIRED)
# ==============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ==============================================
# WhatsApp Business API (REQUIRED for Inbox)
# ==============================================
VITE_WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_id
VITE_WHATSAPP_PHONE_NUMBER_ID=your_phone_id
VITE_WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
VITE_WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_secure_string

# ==============================================
# Bunny.net CDN (REQUIRED for Design Upload)
# ==============================================
VITE_BUNNY_NET_API_KEY=your_storage_zone_password
VITE_BUNNY_NET_STORAGE_ZONE=your_storage_zone_name
VITE_BUNNY_NET_CDN_URL=https://your-pull-zone.b-cdn.net

# ==============================================
# Google Drive Integration (OPTIONAL)
# ==============================================
# VITE_GOOGLE_CLIENT_ID=your_oauth_client_id
# VITE_GOOGLE_API_KEY=your_api_key

# ==============================================
# n8n Automation (OPTIONAL)
# ==============================================
# VITE_N8N_API_URL=https://your-n8n.com/webhook
# VITE_N8N_API_KEY=your_n8n_api_key

# ==============================================
# Appsmith Integration (OPTIONAL)
# ==============================================
# VITE_APPSMITH_API_URL=https://app.appsmith.com
# VITE_APPSMITH_API_KEY=your_key

# ==============================================
# KVM-1 Server Management (OPTIONAL)
# ==============================================
# VITE_KVM1_API_URL=https://kvm.provider.com
# VITE_KVM1_API_KEY=your_key